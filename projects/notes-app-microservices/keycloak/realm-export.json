{
  "realm": "notesapp",
  "enabled": true,
  "registrationAllowed": true,
  "sslRequired": "none",
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      { "name": "user", "description": "Utilisateur standard" },
      { "name": "admin", "description": "Administrateur" }
    ]
  },
  "users": [
    {
      "username": "user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "email": "user@example.local",
      "credentials": [
        { "type": "password", "value": "user123", "temporary": false }
      ],
      "realmRoles": ["user", "admin"]
    }
  ],
  "clients": [
    {
      "clientId": "notesapp-frontend",
      "name": "Notes App Frontend",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:4300",
      "baseUrl": "http://localhost:4300",
      "redirectUris": ["http://localhost:4300/*"],
      "webOrigins": ["http://localhost:4300"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4300/*"
      }
    }
  ]
}
