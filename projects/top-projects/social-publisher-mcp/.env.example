# --- MCP server ---
MCP_API_KEY=
CREDENTIALS_ENC_KEY=            # 32-byte base64 (e.g. `openssl rand -base64 32`)

# --- Database ---
DB_URL=jdbc:postgresql://postgres:5432/socialpub
DB_USER=socialpub
DB_PASSWORD=

# --- Object storage (MinIO) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=media-staging

# --- Meta (Instagram + Facebook Pages) ---
META_APP_ID=
META_APP_SECRET=

# --- TikTok ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- X (Twitter) ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_OAUTH2_TOKEN=

# --- Google (YouTube) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth callbacks ---
PUBLIC_BASE_URL=http://localhost:8080
